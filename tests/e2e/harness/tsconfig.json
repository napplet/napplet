{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "paths": {
      "@test/helpers": ["../../helpers/index.ts"],
      "@test/helpers/*": ["../../helpers/*"]
    }
  },
  "include": ["*.ts", "**/*.ts"]
}
