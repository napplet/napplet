{
  "name": "@napplet/runtime",
  "version": "0.1.0",
  "description": "Browser-agnostic protocol engine for the napplet protocol — message dispatch, ACL enforcement, AUTH handshake, subscription lifecycle",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@napplet/core": "workspace:*",
    "@napplet/acl": "workspace:*",
    "@noble/hashes": "^2.0.0",
    "@noble/curves": "^2.0.0"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "build": "tsup",
    "type-check": "tsc --noEmit",
    "test:unit": "vitest run"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sandwichfarm/napplet.git",
    "directory": "packages/runtime"
  },
  "keywords": ["nostr", "napplet", "runtime", "protocol-engine", "acl"]
}
