{
  "name": "@napplet/services",
  "version": "0.1.0",
  "description": "Reference service implementations for the napplet protocol — audio management, notifications, and more",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@napplet/core": "workspace:*",
    "@napplet/runtime": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "build": "tsup",
    "type-check": "tsc --noEmit",
    "test:unit": "vitest run"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sandwichfarm/napplet.git",
    "directory": "packages/services"
  },
  "keywords": ["nostr", "napplet", "services", "audio", "notifications"]
}
