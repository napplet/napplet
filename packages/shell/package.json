{
  "name": "@napplet/shell",
  "version": "0.1.0-alpha.1",
  "description": "Napplet shell runtime — pseudo-relay, ACL enforcement, signer proxy, storage proxy, audio manager for hosting Nostr-native iframe applications",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@napplet/core": "workspace:*"
  },
  "peerDependencies": {
    "nostr-tools": ">=2.23.3 <3.0.0"
  },
  "devDependencies": {
    "nostr-tools": "^2.23.3",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "build": "tsup",
    "type-check": "tsc --noEmit",
    "test": "vitest run"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sandwichfarm/napplet.git",
    "directory": "packages/shell"
  },
  "keywords": ["nostr", "napplet", "shell", "pseudo-relay", "acl", "iframe"]
}
